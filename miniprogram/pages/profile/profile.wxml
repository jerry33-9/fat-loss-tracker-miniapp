<view class="container">
  <!-- 用户信息 -->
  <view class="card profile-card">
    <view class="flex-row">
      <image class="avatar" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="profile-info">
        <view class="nickname">{{nickName || '减脂人'}}</view>
        <view class="text-hint">坚持记录，遇见更好的自己</view>
      </view>
    </view>
  </view>

  <!-- 目标设定 -->
  <view class="card">
    <view class="card-title">减脂目标</view>
    <view class="goal-item flex-between" wx:if="{{hasGoal}}">
      <view>
        <view class="text-secondary">目标体重</view>
        <view class="goal-value">{{goal.targetWeight}} kg</view>
      </view>
      <view>
        <view class="text-secondary">起始体重</view>
        <view class="goal-value">{{goal.startWeight}} kg</view>
      </view>
      <view>
        <view class="text-secondary">已减</view>
        <view class="goal-value highlight">
          {{weightLost}} kg
        </view>
      </view>
    </view>

    <view class="goal-form" wx:else>
      <view class="form-row">
        <text class="form-label">当前体重</text>
        <input class="form-input" type="digit" placeholder="kg" value="{{startWeight}}" bindinput="onStartWeight" />
      </view>
      <view class="form-row">
        <text class="form-label">目标体重</text>
        <input class="form-input" type="digit" placeholder="kg" value="{{targetWeight}}" bindinput="onTargetWeight" />
      </view>
      <view class="form-row">
        <text class="form-label">每周目标</text>
        <picker range="{{weeklyOptions}}" value="{{weeklyIndex}}" bindchange="onWeeklyChange">
          <view class="form-picker">{{weeklyOptions[weeklyIndex]}}</view>
        </picker>
      </view>
      <button class="btn-primary" bindtap="saveGoal" style="margin-top: 24rpx;">设定目标</button>
    </view>

    <button class="btn-outline" bindtap="editGoal" wx:if="{{hasGoal}}" style="margin-top: 16rpx;">修改目标</button>
  </view>

  <!-- 身高 -->
  <view class="card">
    <view class="card-title">身体数据</view>
    <view class="form-row">
      <text class="form-label">身高</text>
      <input class="form-input" type="digit" placeholder="cm" value="{{height}}" bindinput="onHeight" bindblur="saveHeight" />
    </view>
    <view class="bmi-display" wx:if="{{bmi > 0}}">
      <text>BMI: </text>
      <text class="bmi-value" style="color: {{bmiInfo.color}}">{{bmi}}</text>
      <text class="bmi-label" style="color: {{bmiInfo.color}}"> {{bmiInfo.label}}</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="card">
    <view class="card-title">数据统计</view>
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-num">{{stats.totalWeights}}</view>
        <view class="stat-label">体重记录</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.totalDiets}}</view>
        <view class="stat-label">饮食记录</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.totalExercises}}</view>
        <view class="stat-label">运动记录</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.streakDays}}</view>
        <view class="stat-label">连续天数</view>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="card about-card">
    <view class="about-text">减脂记录 v1.0.0</view>
    <view class="about-text text-hint">科学减脂 · 健康生活</view>
  </view>
</view>
