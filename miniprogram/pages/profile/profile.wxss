.profile-card {
  background: linear-gradient(135deg, #00B578, #00D68F);
  color: #FFFFFF;
}

.profile-card .text-hint {
  color: rgba(255,255,255,0.75);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.4);
  background: rgba(255,255,255,0.2);
}

.profile-info {
  margin-left: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.goal-item {
  padding: 16rpx 0;
}

.goal-value {
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.goal-value.highlight {
  color: var(--primary);
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.form-input {
  font-size: 28rpx;
  text-align: right;
  width: 200rpx;
}

.form-picker {
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 8rpx 16rpx;
}

.bmi-display {
  padding-top: 16rpx;
  font-size: 28rpx;
}

.bmi-value {
  font-size: 40rpx;
  font-weight: 700;
}

.bmi-label {
  font-size: 28rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.stat-item {
  text-align: center;
  padding: 24rpx;
  background: var(--bg-page);
  border-radius: 12rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

.about-card {
  text-align: center;
  padding: 40rpx;
}

.about-text {
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.3);
  font-size: 48rpx;
}
