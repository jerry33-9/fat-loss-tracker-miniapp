.input-group {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.input-label {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.input-value {
  font-size: 28rpx;
  padding: 16rpx 0;
}

.meal-tabs {
  display: flex;
  gap: 16rpx;
}

.meal-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: var(--bg-page);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.meal-tab.active {
  background: var(--primary);
  color: #FFFFFF;
}

.btn-add-food {
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 500;
  background: none;
  border: none;
  padding: 0;
}

.food-edit-list {
  margin-top: 16rpx;
}

.food-edit-item {
  background: var(--bg-page);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.food-edit-row {
  margin-bottom: 12rpx;
}

.food-name-input {
  font-size: 28rpx;
  flex: 1;
  padding: 8rpx 0;
}

.food-amount-input {
  font-size: 28rpx;
  width: 160rpx;
  text-align: right;
  padding: 8rpx 0;
  color: var(--text-secondary);
}

.food-cal-input {
  font-size: 28rpx;
  width: 200rpx;
  padding: 8rpx 0;
  color: var(--primary);
}

.food-delete {
  font-size: 24rpx;
  color: var(--danger);
}

.photo-area {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.photo-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #EEE;
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--border);
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.photo-add-icon {
  font-size: 48rpx;
  color: var(--text-hint);
  line-height: 1;
}

.photo-add-text {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.calorie-summary {
  text-align: center;
  font-size: 32rpx;
  padding: 24rpx 0;
  color: var(--text-secondary);
}

.cal-value {
  color: var(--primary);
  font-size: 44rpx;
  font-weight: 700;
}

.note-input {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
}
