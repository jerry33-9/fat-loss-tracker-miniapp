<view class="container">
  <view class="flex-between mb-24">
    <view class="text-secondary">共 {{totalRecords}} 条记录</view>
    <button class="btn-outline" bindtap="goLog" size="mini">+ 记录体重</button>
  </view>

  <view class="card" wx:if="{{trendValues.length > 1}}">
    <view class="card-title">趋势图</view>
    <canvas type="2d" id="weightTrendChart" class="chart-canvas"></canvas>
  </view>

  <view class="card" wx:if="{{records.length > 0}}">
    <view class="card-title">历史记录</view>
    <view class="record-item flex-between" wx:for="{{records}}" wx:key="_id">
      <view>
        <view class="record-date">{{item.dateLabel}}</view>
        <view class="record-note text-hint" wx:if="{{item.note}}">{{item.note}}</view>
      </view>
      <view class="flex-row">
        <view class="record-diff {{item.diff > 0 ? 'up' : item.diff < 0 ? 'down' : ''}}" wx:if="{{item.diff !== undefined}}">
          {{item.diff > 0 ? '+' : ''}}{{item.diff}} kg
        </view>
        <view class="record-weight">{{item.weight}} kg</view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text>还没有体重记录</text>
    <button class="btn-primary mt-24" bindtap="goLog">开始记录</button>
  </view>
</view>
