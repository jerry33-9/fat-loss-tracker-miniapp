.input-group {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.input-label {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.input-value {
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 16rpx 0;
}

.weight-input-row {
  display: flex;
  align-items: baseline;
}

.weight-input {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--primary);
  width: 300rpx;
}

.input-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

.quick-weights {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.quick-weight {
  padding: 12rpx 28rpx;
  background: var(--bg-page);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.quick-weight.active {
  background: var(--primary-light);
  color: var(--primary);
  font-weight: 600;
}

.note-input {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
}

.last-weight {
  font-size: 36rpx;
  font-weight: 700;
}
