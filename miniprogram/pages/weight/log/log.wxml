<view class="container">
  <view class="card">
    <view class="input-group">
      <view class="input-label">日期</view>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="input-value">{{dateLabel}}</view>
      </picker>
    </view>

    <view class="input-group">
      <view class="input-label">体重</view>
      <view class="weight-input-row">
        <input
          class="weight-input"
          type="digit"
          placeholder="输入体重"
          value="{{weight}}"
          bindinput="onWeightInput"
          focus="{{true}}"
        />
        <text class="input-unit">kg</text>
      </view>
    </view>

    <view class="quick-weights">
      <view
        class="quick-weight {{item === selectedQuick ? 'active' : ''}}"
        wx:for="{{quickWeights}}"
        wx:key="*this"
        data-weight="{{item}}"
        bindtap="setQuickWeight"
      >
        {{item}}
      </view>
    </view>

    <view class="input-group">
      <view class="input-label">备注</view>
      <textarea
        class="note-input"
        placeholder="记录当时状态（选填）"
        value="{{note}}"
        bindinput="onNoteInput"
        maxlength="100"
        auto-height
      />
    </view>

    <button class="btn-primary" bindtap="save" style="margin-top: 32rpx;">保存</button>
  </view>

  <view class="card" wx:if="{{lastRecord}}">
    <view class="card-title">上一次记录</view>
    <view class="flex-between">
      <view class="text-secondary">{{lastRecord.dateLabel}}</view>
      <view class="last-weight">{{lastRecord.weight}} kg</view>
    </view>
  </view>
</view>
