.chart-canvas {
  width: 100%;
  height: 360rpx;
}

.record-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 28rpx;
  font-weight: 500;
}

.record-note {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.record-diff {
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 16rpx;
  min-width: 80rpx;
  text-align: right;
}

.record-diff.up { color: #FF6B6B; }
.record-diff.down { color: #00B578; }

.record-weight {
  font-size: 36rpx;
  font-weight: 700;
  min-width: 120rpx;
  text-align: right;
}
