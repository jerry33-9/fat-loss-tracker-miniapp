.date-header {
  font-size: 32rpx;
  font-weight: 600;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border);
  margin-bottom: 16rpx;
}

.workout-item {
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.workout-item:last-of-type {
  border-bottom: none;
  margin-bottom: 0;
}

.wo-exercise {
  padding: 8rpx 0;
}

.wo-ex-name {
  font-size: 28rpx;
  font-weight: 500;
}

.wo-ex-detail {
  font-size: 24rpx;
  margin-left: 12rpx;
}

.wo-footer {
  padding-top: 8rpx;
}

.wo-note {
  font-size: 24rpx;
  flex: 1;
}

.wo-dur {
  font-size: 24rpx;
  color: var(--primary);
}

.date-summary {
  text-align: right;
  padding-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-top: 1rpx solid var(--border);
}
