page {
  --primary: #16213E;
  --primary-light: #E8EDF5;
  --accent: #0F3460;
  --danger: #E94560;
  --text-primary: #1A1A2E;
  --text-secondary: #666666;
  --text-hint: #999999;
  --bg-page: #F5F5F5;
  --bg-card: #FFFFFF;
  --border: #EEEEEE;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: var(--text-primary);
  background-color: var(--bg-page);
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 20rpx 48rpx;
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-hint { color: var(--text-hint); }
.text-secondary { color: var(--text-secondary); }
.mt-24 { margin-top: 24rpx; }
.mb-24 { margin-bottom: 24rpx; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-hint);
}
