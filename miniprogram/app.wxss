page {
  --primary: #00B578;
  --primary-light: #E8F8F2;
  --danger: #FF4D4F;
  --warning: #FAAD14;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --bg-page: #F5F5F5;
  --bg-card: #FFFFFF;
  --border: #EEEEEE;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: var(--text-primary);
  background-color: var(--bg-page);
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 20rpx 48rpx;
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
}

.text-secondary {
  color: var(--text-secondary);
}

.text-hint {
  color: var(--text-hint);
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.text-center {
  text-align: center;
}

.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-hint);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}
